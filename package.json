{
  "name": "glossa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "req:scan": "TMPDIR=/tmp tsx tools/requirements/src/main.ts scan",
    "req:fmt-agents": "TMPDIR=/tmp tsx tools/requirements/src/main.ts fmt-agents",
    "req:check:staged": "TMPDIR=/tmp tsx tools/requirements/src/main.ts check --staged",
    "req:check:all": "TMPDIR=/tmp tsx tools/requirements/src/main.ts check --all",
    "req:check": "TMPDIR=/tmp tsx tools/requirements/src/main.ts check",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/chrome": "^0.0.315",
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "jsdom": "^26.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "p-limit": "^7.3.0"
  }
}
