{
  "name": "glossa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:requirements",
    "test:unit": "vitest run --exclude 'tests/requirements/**'",
    "test:requirements": "vitest run tests/requirements/tool.test.ts --testTimeout=120000 && vitest run tests/requirements/anchoring-regressions.test.ts tests/requirements/source-snapshot-regressions.test.ts tests/requirements/full-source-regressions.test.ts --testTimeout=120000",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run req:check:all && npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "req:scan": "node scripts/run-requirements.mjs scan",
    "req:fmt-agents": "node scripts/run-requirements.mjs fmt-agents",
    "req:check:staged": "node scripts/run-requirements.mjs check --staged",
    "req:check:all": "node scripts/run-requirements.mjs check --all",
    "req:check": "node scripts/run-requirements.mjs check",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/chrome": "^0.0.315",
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "jsdom": "^26.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "p-limit": "^7.3.0"
  }
}
