---
import "../styles/global.css";

const repoUrl = "https://github.com/JiaJunDeng5930/glossa";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Glossa AI 官网" />
    <link rel="icon" href="data:," />
    <title>Glossa AI</title>
  </head>
  <body>
    <header class="site-nav" aria-label="主导航">
      <a class="nav-brand" href="#" aria-label="Glossa AI 首页">
        <img class="nav-logo" src="/assets/logo.png" alt="" />
      </a>
      <nav>
        <a class="nav-link download-pill" href={repoUrl} target="_blank" rel="noreferrer">下载</a>
      </nav>
    </header>

    <main>
      <section class="story story-desktop" id="features" aria-label="Glossa AI 阅读与制卡演示" data-story>
        <div class="stage">
          <div class="stage-shell">
            <div class="left-viewport">
              <div class="left-track" data-left-track>
                <section class="left-panel hero-panel">
                  <h1 class="brand-title">Glossa AI</h1>
                  <p class="brand-subtitle">你阅读和学习英语的新方式</p>
                  <div class="ink-scene" aria-hidden="true">
                    <svg class="ink-line" viewBox="0 0 600 210">
                      <path d="M12 50 C94 16 154 30 213 68 C270 106 324 111 383 154"></path>
                    </svg>
                    <img class="quill-image" src="/assets/quill.png" alt="" />
                  </div>
                </section>

                <section class="left-panel">
                  <h2>流畅阅读，<br />即时无障碍</h2>
                  <p>
                    阅读英文文段的时候，Glossa 为您智能翻译生词。根据您的设置和历史记录筛选生词；使用 AI
                    智能提供最符合语境的翻译。
                  </p>
                </section>

                <section class="left-panel">
                  <h2>智能制卡，<br />巩固学习</h2>
                  <p>长按 Alt 键并且点击您需要制卡的单词，让 AI 为您智能制作 Anki 卡片，学习您不会的生词。</p>
                </section>
              </div>
            </div>

            <div class="right-stage">
              <article class="reading-demo" aria-label="英文阅读演示" data-reading-demo>
                <p class="reading-copy">
                  Glossa AI helps you read English with
                  <span class="gloss-token gloss-1"><span class="gloss-label">自信</span><span class="source-word">confidence</span></span>
                  by showing just the right Chinese glosses for words that
                  <span class="gloss-token gloss-2"><span class="gloss-label">重要</span><span class="source-word">matter</span></span>.
                  Each gloss appears in
                  <span class="gloss-token gloss-3"><span class="gloss-label">语境</span><span class="source-word">context</span></span>,
                  so you can grasp meaning without breaking your flow. For serious readers, this support becomes
                  <span class="gloss-token gloss-4 card-target"><span class="gloss-label">必不可少</span><span class="source-word">indispensable<img class="word-pointer" src="/assets/mouse-pointer.png" alt="" /></span></span>
                  when long articles introduce
                  <span class="gloss-token gloss-5"><span class="gloss-label">陌生</span><span class="source-word">unfamiliar</span></span>
                  vocabulary, subtle phrasing, and ideas that deserve careful attention.
                </p>

                <div class="carding-layer" aria-hidden="true">
                  <img class="alt-key" src="/assets/alt-key.png" alt="" />
                  <div class="reading-mask"></div>
                  <section class="anki-card" aria-label="Anki 卡片示意">
                    <div class="anki-title">Anki</div>
                    <div class="anki-row">
                      <span>Front</span>
                      <strong>indispensable</strong>
                    </div>
                    <div class="anki-row">
                      <span>Back</span>
                      <p>不可或缺的；必不可少的</p>
                    </div>
                    <div class="anki-example">
                      For serious readers, this support becomes indispensable.
                    </div>
                  </section>
                </div>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="mobile-story" aria-label="Glossa AI 移动端叙事">
        <section class="mobile-panel hero-panel">
          <h1 class="brand-title">Glossa AI</h1>
          <p class="brand-subtitle">你阅读和学习英语的新方式</p>
          <div class="ink-scene" aria-hidden="true">
            <svg class="ink-line" viewBox="0 0 600 210">
              <path d="M12 50 C94 16 154 30 213 68 C270 106 324 111 383 154"></path>
            </svg>
            <img class="quill-image" src="/assets/quill.png" alt="" />
          </div>
        </section>

        <article class="reading-demo mobile-reading mobile-reading-plain" aria-label="英文阅读演示">
          <p class="reading-copy">
            Glossa AI helps you read English with
            <span class="gloss-token gloss-1"><span class="gloss-label">自信</span><span class="source-word">confidence</span></span>
            by showing just the right Chinese glosses for words that
            <span class="gloss-token gloss-2"><span class="gloss-label">重要</span><span class="source-word">matter</span></span>.
            Each gloss appears in
            <span class="gloss-token gloss-3"><span class="gloss-label">语境</span><span class="source-word">context</span></span>,
            so you can grasp meaning without breaking your flow. For serious readers, this support becomes
            <span class="gloss-token gloss-4 card-target"><span class="gloss-label">必不可少</span><span class="source-word">indispensable<img class="word-pointer" src="/assets/mouse-pointer.png" alt="" /></span></span>
            when long articles introduce
            <span class="gloss-token gloss-5"><span class="gloss-label">陌生</span><span class="source-word">unfamiliar</span></span>
            vocabulary, subtle phrasing, and ideas that deserve careful attention.
          </p>
        </article>

        <section class="mobile-panel">
          <h2>流畅阅读，<br />即时无障碍</h2>
          <p>
            阅读英文文段的时候，Glossa 为您智能翻译生词。根据您的设置和历史记录筛选生词；使用 AI
            智能提供最符合语境的翻译。
          </p>
        </section>

        <article class="reading-demo mobile-reading mobile-reading-gloss" aria-label="英文翻译演示">
          <p class="reading-copy">
            Glossa AI helps you read English with
            <span class="gloss-token gloss-1"><span class="gloss-label">自信</span><span class="source-word">confidence</span></span>
            by showing just the right Chinese glosses for words that
            <span class="gloss-token gloss-2"><span class="gloss-label">重要</span><span class="source-word">matter</span></span>.
            Each gloss appears in
            <span class="gloss-token gloss-3"><span class="gloss-label">语境</span><span class="source-word">context</span></span>,
            so you can grasp meaning without breaking your flow. For serious readers, this support becomes
            <span class="gloss-token gloss-4 card-target"><span class="gloss-label">必不可少</span><span class="source-word">indispensable<img class="word-pointer" src="/assets/mouse-pointer.png" alt="" /></span></span>
            when long articles introduce
            <span class="gloss-token gloss-5"><span class="gloss-label">陌生</span><span class="source-word">unfamiliar</span></span>
            vocabulary, subtle phrasing, and ideas that deserve careful attention.
          </p>
        </article>

        <section class="mobile-panel">
          <h2>智能制卡，<br />巩固学习</h2>
          <p>长按 Alt 键并且点击您需要制卡的单词，让 AI 为您智能制作 Anki 卡片，学习您不会的生词。</p>
        </section>

        <article class="reading-demo mobile-reading mobile-reading-card" aria-label="Anki 制卡演示">
          <div class="mobile-card-reading-shell">
            <p class="reading-copy">
              Glossa AI helps you read English with
              <span class="gloss-token gloss-1"><span class="gloss-label">自信</span><span class="source-word">confidence</span></span>
              by showing just the right Chinese glosses for words that
              <span class="gloss-token gloss-2"><span class="gloss-label">重要</span><span class="source-word">matter</span></span>.
              Each gloss appears in
              <span class="gloss-token gloss-3"><span class="gloss-label">语境</span><span class="source-word">context</span></span>,
              so you can grasp meaning without breaking your flow. For serious readers, this support becomes
              <span class="gloss-token gloss-4 card-target"><span class="gloss-label">必不可少</span><span class="source-word">indispensable<img class="word-pointer" src="/assets/mouse-pointer.png" alt="" /></span></span>
              when long articles introduce
              <span class="gloss-token gloss-5"><span class="gloss-label">陌生</span><span class="source-word">unfamiliar</span></span>
              vocabulary, subtle phrasing, and ideas that deserve careful attention.
            </p>

            <div class="carding-layer" aria-hidden="true">
              <img class="alt-key" src="/assets/alt-key.png" alt="" />
              <div class="reading-mask"></div>
            </div>
          </div>

          <section class="anki-card" aria-label="Anki 卡片示意">
            <div class="anki-title">Anki</div>
            <div class="anki-row">
              <span>Front</span>
              <strong>indispensable</strong>
            </div>
            <div class="anki-row">
              <span>Back</span>
              <p>不可或缺的；必不可少的</p>
            </div>
            <div class="anki-example">
              For serious readers, this support becomes indispensable.
            </div>
          </section>
        </article>
      </section>
    </main>

    <script>
      const story = document.querySelector("[data-story]");
      const leftTrack = document.querySelector("[data-left-track]");
      const readingDemo = document.querySelector("[data-reading-demo]");

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      function segment(value, start, end) {
        return clamp((value - start) / (end - start), 0, 1);
      }

      function heldStageProgress(value) {
        if (value < 0.3) {
          return segment(value, 0, 0.3);
        }

        if (value < 0.52) {
          return 1;
        }

        if (value < 0.68) {
          return 1 + segment(value, 0.52, 0.68);
        }

        return 2;
      }

      function updateStory() {
        if (!story || !leftTrack || !readingDemo) {
          return;
        }

        const isDesktopStage = window.matchMedia("(min-width: 1024px) and (min-height: 600px)").matches;
        if (!isDesktopStage) {
          leftTrack.style.transform = "";
          readingDemo.style.setProperty("--gloss-progress", "1");
          readingDemo.style.setProperty("--gloss-1", "1");
          readingDemo.style.setProperty("--gloss-2", "1");
          readingDemo.style.setProperty("--gloss-3", "1");
          readingDemo.style.setProperty("--gloss-4", "1");
          readingDemo.style.setProperty("--gloss-5", "1");
          readingDemo.style.setProperty("--alt-progress", "1");
          readingDemo.style.setProperty("--mask-progress", "1");
          readingDemo.style.setProperty("--click-progress", "1");
          readingDemo.style.setProperty("--card-progress", "1");
          return;
        }

        const scrollable = story.offsetHeight - window.innerHeight;
        if (scrollable <= 0) {
          return;
        }
        const progress = clamp(-story.getBoundingClientRect().top / scrollable, 0, 1);
        const leftProgress = heldStageProgress(progress);
        const glossStages = [
          ["--gloss-1", 0.05, 0.09],
          ["--gloss-2", 0.1, 0.14],
          ["--gloss-3", 0.15, 0.19],
          ["--gloss-4", 0.2, 0.24],
          ["--gloss-5", 0.25, 0.29],
        ];
        const overlayProgress = segment(progress, 0.53, 0.57);

        leftTrack.style.transform = `translateY(${-leftProgress * 33.3333}%)`;
        readingDemo.style.setProperty("--gloss-progress", String(segment(progress, 0.05, 0.29)));
        for (const [property, start, end] of glossStages) {
          readingDemo.style.setProperty(property, String(segment(progress, start, end)));
        }
        readingDemo.style.setProperty("--alt-progress", String(overlayProgress));
        readingDemo.style.setProperty("--mask-progress", String(overlayProgress));
        readingDemo.style.setProperty("--click-progress", String(segment(progress, 0.59, 0.62)));
        readingDemo.style.setProperty("--card-progress", String(segment(progress, 0.64, 0.68)));
      }

      window.addEventListener("scroll", updateStory, { passive: true });
      window.addEventListener("resize", updateStory);
      updateStory();
    </script>
  </body>
</html>
