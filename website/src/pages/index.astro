---
import globalCss from "../styles/global.css?raw";

const repoUrl = "https://github.com/JiaJunDeng5930/glossa";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Glossa AI 是面向中文用户的 Chrome 英文阅读扩展，在网页生词上方显示中文释义，并支持 Alt 点击加入 Anki。"
    />
    <link rel="icon" href="data:," />
    <title>Glossa AI - 英文长文，读得更顺</title>
    <style is:inline set:html={globalCss}></style>
  </head>
  <body>
    <header class="site-nav" aria-label="主导航">
      <a class="nav-brand" href="#" aria-label="Glossa AI 首页">
        <img class="nav-logo" src="/assets/logo.png" alt="Glossa AI" />
      </a>
      <nav aria-label="站点导航">
        <a class="nav-link" href="#workflow">工作方式</a>
        <a class="nav-link" href="#anki">Anki 制卡</a>
        <a class="nav-link" href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
        <a class="nav-link download-pill" href={repoUrl} target="_blank" rel="noreferrer">获取 Glossa</a>
      </nav>
    </header>

    <main>
      <section class="story story-desktop" id="workflow" aria-label="Glossa AI 滚动演示" data-story>
        <div class="stage">
          <div class="stage-shell">
            <div class="left-viewport">
              <div class="left-track" data-left-track>
                <section class="left-panel hero-panel">
                  <h1>英文长文，<br />读得更顺</h1>
                  <p>
                    Glossa 在网页里的生词上方显示中文释义，让你不断流也能读懂上下文。遇到值得记住的词，按住 Alt 点击即可加入 Anki。
                  </p>
                  <div class="hero-actions">
                    <a class="primary-button" href={repoUrl} target="_blank" rel="noreferrer">获取 Glossa</a>
                    <a class="text-link" href="#anki">查看 Anki 制卡</a>
                  </div>
                </section>

                <section class="left-panel">
                  <h2>只在需要时<br />显示中文释义</h2>
                  <p>
                    熟词保持安静，生词在原文上方轻轻出现。你看见的是文章本身，释义只在真正需要时补上。
                  </p>
                </section>

                <section class="left-panel">
                  <h2>按住 Alt，<br />把生词加入 Anki</h2>
                  <p>
                    选中值得记住的词，Glossa 生成卡片内容，连接你的长期记忆。
                  </p>
                </section>
              </div>
            </div>

            <div class="right-stage">
              <article class="reading-demo browser-demo" aria-label="Glossa AI 网页阅读演示" data-reading-demo>
                <div class="browser-bar" aria-hidden="true">
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                  <span class="browser-url">article.example.com/deep-reading</span>
                </div>
                <div class="article-page">
                  <p class="article-kicker">Long-form reading</p>
                  <p class="reading-copy" data-glossa-demo-copy>
                    Long articles reward a steady pace. Glossa keeps the sentence intact while a quiet gloss clarifies context only where it helps. The note stays close to the word, so subtle meaning remains part of the line. When a term becomes indispensable, hold Alt and click to prepare Anki. New vocabulary can move into a simple review flow.
                  </p>
                  <p class="reading-copy">
                    A second paragraph keeps the page feeling like a real article. The reader can continue scanning the next thought while the translated line above expands naturally in the same text flow.
                  </p>
                </div>

                <div class="carding-layer" aria-hidden="true">
                  <img class="alt-key" src="/assets/alt-key.png" alt="" />
                  <div class="reading-mask"></div>
                  <section class="anki-card" aria-label="Anki 卡片预览">
                    <div class="anki-title">Anki</div>
                    <div class="anki-row">
                      <span>正面</span>
                      <strong>indispensable</strong>
                    </div>
                    <div class="anki-row">
                      <span>背面</span>
                      <p>不可或缺的</p>
                    </div>
                    <p class="anki-example">
                      For serious readers, this support becomes indispensable.
                    </p>
                    <div class="anki-action">加入 Anki</div>
                  </section>
                </div>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="mobile-story" aria-label="Glossa AI 移动端演示">
        <section class="mobile-panel hero-panel">
          <h1>英文长文，<br />读得更顺</h1>
          <p>
            Glossa 在网页里的生词上方显示中文释义，让你不断流也能读懂上下文。遇到值得记住的词，按住 Alt 点击即可加入 Anki。
          </p>
          <div class="hero-actions">
            <a class="primary-button" href={repoUrl} target="_blank" rel="noreferrer">获取 Glossa</a>
            <a class="text-link" href="#anki">查看 Anki 制卡</a>
          </div>
        </section>

        <article class="reading-demo browser-demo mobile-reading mobile-reading-plain" aria-label="网页阅读演示">
          <div class="article-page">
            <p class="reading-copy">
              Glossa keeps long-form reading calm and focused. A quiet gloss explains context without breaking the page.
            </p>
          </div>
        </article>

        <section class="mobile-panel">
          <h2>只在需要时<br />显示中文释义</h2>
          <p>
            熟词保持安静，生词在原文上方轻轻出现。你看见的是文章本身，释义只在真正需要时补上。
          </p>
        </section>

        <article class="reading-demo browser-demo mobile-reading mobile-reading-gloss" aria-label="中文释义演示">
          <div class="article-page">
            <p class="reading-copy">
              Glossa keeps long-form reading calm and focused. A quiet gloss explains <span class="notranslate" translate="no" data-glossa-owned="1" data-glossa-token data-glossa-status="ready" data-glossa-display-kind="gloss" data-glossa-surface="context" data-glossa-display="语境" data-glossa-gloss-display="语境"><span data-glossa-owned="1" data-glossa-token-width translate="no">语境</span><span data-glossa-owned="1" data-glossa-token-label translate="no">语境</span><span data-glossa-owned="1" data-glossa-token-surface translate="no">context</span></span>. <span class="notranslate" translate="no" data-glossa-owned="1" data-glossa-token data-glossa-status="ready" data-glossa-display-kind="gloss" data-glossa-surface="Subtle" data-glossa-display="细微" data-glossa-gloss-display="细微"><span data-glossa-owned="1" data-glossa-token-width translate="no">细微</span><span data-glossa-owned="1" data-glossa-token-label translate="no">细微</span><span data-glossa-owned="1" data-glossa-token-surface translate="no">Subtle</span></span> meaning stays close to the sentence.
            </p>
          </div>
        </article>

        <section class="mobile-panel">
          <h2>按住 Alt，<br />把生词加入 Anki</h2>
          <p>
            选中值得记住的词，Glossa 生成卡片内容，连接你的长期记忆。
          </p>
        </section>

        <article class="reading-demo browser-demo mobile-reading mobile-reading-card" aria-label="Anki 制卡演示">
          <div class="mobile-card-reading-shell">
            <div class="article-page">
              <p class="reading-copy">
                For serious readers, this support becomes <span class="card-target notranslate" translate="no" data-glossa-owned="1" data-glossa-token data-glossa-status="ready" data-glossa-display-kind="gloss" data-glossa-surface="indispensable" data-glossa-display="不可或缺" data-glossa-gloss-display="不可或缺"><span data-glossa-owned="1" data-glossa-token-width translate="no">不可或缺</span><span data-glossa-owned="1" data-glossa-token-label translate="no">不可或缺</span><span data-glossa-owned="1" data-glossa-token-surface translate="no">indispensable<img class="word-pointer" src="/assets/mouse-pointer.png" alt="" /></span></span> when long articles introduce unfamiliar vocabulary.
              </p>
            </div>
            <div class="carding-layer" aria-hidden="true">
              <img class="alt-key" src="/assets/alt-key.png" alt="" />
              <div class="reading-mask"></div>
            </div>
          </div>

          <section class="anki-card" aria-label="Anki 卡片预览">
            <div class="anki-title">Anki</div>
            <div class="anki-row">
              <span>正面</span>
              <strong>indispensable</strong>
            </div>
            <div class="anki-row">
              <span>背面</span>
              <p>不可或缺的</p>
            </div>
            <p class="anki-example">
              For serious readers, this support becomes indispensable.
            </p>
            <div class="anki-action">加入 Anki</div>
          </section>
        </article>
      </section>

      <section class="product-section" id="anki" aria-label="Glossa AI 设置与 Anki 支持">
        <div class="product-shell">
          <div class="settings-preview" aria-label="Glossa AI 设置预览">
            <aside class="settings-rail-preview" aria-hidden="true">
              <img class="settings-logo" src="/assets/logo.png" alt="" />
              <nav>
                <span>阅读</span>
                <span>外观</span>
                <span>AI</span>
                <span>Anki</span>
              </nav>
            </aside>

            <div class="settings-workspace-preview">
              <header class="settings-header-preview">
                <div>
                  <p>Chrome 扩展设置</p>
                  <h3>Glossa 设置</h3>
                </div>
                <span class="save-button-preview">保存</span>
              </header>

              <div class="settings-grid-preview">
                <section class="settings-block">
                  <div>
                    <h3>AI 设置</h3>
                    <p>连接你的常用模型服务。</p>
                  </div>
                  <div class="field-row">
                    <span>Provider</span>
                    <strong>OpenAI Responses</strong>
                  </div>
                  <div class="field-row">
                    <span>请求超时</span>
                    <strong>30 秒</strong>
                  </div>
                  <div class="field-row prompt-row">
                    <span>提示词</span>
                    <strong>按上下文生成简明中文释义</strong>
                  </div>
                </section>

                <section class="settings-block">
                  <div>
                    <h3>Anki 制卡</h3>
                    <p>连接本机 AnkiConnect。</p>
                  </div>
                  <div class="field-row">
                    <span>Endpoint</span>
                    <strong>http://localhost:8765</strong>
                  </div>
                  <div class="field-row">
                    <span>牌组</span>
                    <strong>英语长文阅读</strong>
                  </div>
                  <span class="secondary-button" aria-hidden="true">测试连接</span>
                </section>

                <section class="settings-block compact-settings">
                  <div>
                    <h3>外观控制</h3>
                    <p>释义颜色、字号和透明度都可以按习惯调整。</p>
                  </div>
                  <div class="swatch-row">
                    <span class="swatch swatch-label"></span>
                    <span class="swatch swatch-success"></span>
                    <span class="swatch swatch-error"></span>
                  </div>
                </section>
              </div>
            </div>
          </div>

          <div class="product-copy">
            <h2>为认真阅读和长期记忆设计</h2>
            <p>
              你可以设置 AI 服务、释义样式、已掌握词库和 Anki 连接。Glossa 把页面阅读、词义判断和制卡流程放在同一个轻量扩展里。
            </p>
            <ul class="feature-list" aria-label="Glossa AI 特性">
              <li>中文释义贴在原文上方</li>
              <li>熟词过滤和本地设置保存</li>
              <li>Alt 点击创建 Anki 卡片</li>
              <li>自定义释义与制卡提示词</li>
            </ul>

            <div class="closing-cta">
              <h2>开始用 Glossa 阅读英文</h2>
              <p>开源 Chrome 扩展，适合长文阅读、英语学习和 Anki 复习流。</p>
              <div class="hero-actions">
                <a class="primary-button" href={repoUrl} target="_blank" rel="noreferrer">获取 Glossa</a>
                <a class="text-link" href={repoUrl} target="_blank" rel="noreferrer">查看 GitHub</a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <span>© 2026 Glossa AI</span>
      <a href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
    </footer>

    <script>
      const story = document.querySelector("[data-story]");
      const leftTrack = document.querySelector("[data-left-track]");
      const readingDemo = document.querySelector("[data-reading-demo]");
      const demoCopy = document.querySelector("[data-glossa-demo-copy]");
      const GLOSS_DEMO_TOKENS = [
        "Long articles reward a steady pace. Glossa keeps the sentence intact while a quiet gloss clarifies ",
        { surface: "context", label: "语境", threshold: 0.09 },
        " only where it helps. The note stays close to the word, so ",
        { surface: "subtle", label: "细微", threshold: 0.14 },
        " meaning remains part of the line. When a term becomes ",
        { surface: "indispensable", label: "不可或缺", threshold: 0.19, card: true },
        ", hold Alt and click to prepare Anki. New ",
        { surface: "vocabulary", label: "词汇", threshold: 0.24 },
        " can move into a simple ",
        { surface: "review", label: "复习", threshold: 0.29 },
        " flow.",
      ];
      let renderedDemoStage = "";

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      function segment(value, start, end) {
        return clamp((value - start) / (end - start), 0, 1);
      }

      function heldStageProgress(value) {
        if (value < 0.3) {
          return segment(value, 0, 0.3);
        }

        if (value < 0.52) {
          return 1;
        }

        if (value < 0.68) {
          return 1 + segment(value, 0.52, 0.68);
        }

        return 2;
      }

      function createGlossToken(token) {
        const wrapper = document.createElement("span");
        wrapper.dataset.glossaOwned = "1";
        wrapper.dataset.glossaToken = "";
        wrapper.dataset.glossaSurface = token.surface;
        wrapper.dataset.glossaDisplay = token.label;
        wrapper.dataset.glossaDisplayKind = "gloss";
        wrapper.dataset.glossaGlossDisplay = token.label;
        wrapper.dataset.glossaStatus = "ready";
        wrapper.className = token.card ? "card-target notranslate" : "notranslate";
        wrapper.setAttribute("translate", "no");

        const label = document.createElement("span");
        label.dataset.glossaOwned = "1";
        label.dataset.glossaTokenLabel = "";
        label.setAttribute("translate", "no");
        label.textContent = token.label;

        const width = document.createElement("span");
        width.dataset.glossaOwned = "1";
        width.dataset.glossaTokenWidth = "";
        width.setAttribute("translate", "no");
        width.textContent = token.label;

        const surface = document.createElement("span");
        surface.dataset.glossaOwned = "1";
        surface.dataset.glossaTokenSurface = "";
        surface.setAttribute("translate", "no");
        surface.textContent = token.surface;

        if (token.card) {
          const pointer = document.createElement("img");
          pointer.className = "word-pointer";
          pointer.src = "/assets/mouse-pointer.png";
          pointer.alt = "";
          surface.append(pointer);
        }

        wrapper.append(width, label, surface);
        return wrapper;
      }

      function renderDemoCopy(progress) {
        if (!demoCopy) {
          return;
        }

        const stageKey = GLOSS_DEMO_TOKENS.map((part) => (
          typeof part === "string" || progress >= part.threshold ? "1" : "0"
        )).join("");
        if (stageKey === renderedDemoStage) {
          return;
        }
        renderedDemoStage = stageKey;

        const fragment = document.createDocumentFragment();
        for (const part of GLOSS_DEMO_TOKENS) {
          if (typeof part === "string") {
            fragment.append(document.createTextNode(part));
            continue;
          }

          fragment.append(
            progress >= part.threshold
              ? createGlossToken(part)
              : document.createTextNode(part.surface),
          );
        }

        demoCopy.replaceChildren(fragment);
      }

      function updateStory() {
        if (!story || !leftTrack || !readingDemo) {
          return;
        }

        const isDesktopStage = window.matchMedia("(min-width: 1024px) and (min-height: 600px)").matches;
        if (!isDesktopStage) {
          leftTrack.style.transform = "";
          renderDemoCopy(1);
          readingDemo.style.setProperty("--alt-progress", "1");
          readingDemo.style.setProperty("--mask-progress", "1");
          readingDemo.style.setProperty("--click-progress", "1");
          readingDemo.style.setProperty("--card-progress", "1");
          return;
        }

        const scrollable = story.offsetHeight - window.innerHeight;
        if (scrollable <= 0) {
          return;
        }
        const progress = clamp(-story.getBoundingClientRect().top / scrollable, 0, 1);
        const leftProgress = heldStageProgress(progress);
        const overlayProgress = segment(progress, 0.53, 0.57);

        leftTrack.style.transform = `translateY(${-leftProgress * 33.3333}%)`;
        renderDemoCopy(progress);
        readingDemo.style.setProperty("--alt-progress", String(overlayProgress));
        readingDemo.style.setProperty("--mask-progress", String(overlayProgress));
        readingDemo.style.setProperty("--click-progress", String(segment(progress, 0.59, 0.62)));
        readingDemo.style.setProperty("--card-progress", String(segment(progress, 0.64, 0.68)));
      }

      window.addEventListener("scroll", updateStory, { passive: true });
      window.addEventListener("resize", updateStory);
      updateStory();
    </script>
  </body>
</html>
